{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@cave/ai": ["./packages/ai/src/index.ts"],
			"@cave/ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@cave/ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@cave/ai/dist/*": ["./packages/ai/src/*"],
			"@cave/agent": ["./packages/agent/src/index.ts"],
			"@cave/agent/*": ["./packages/agent/src/*"],
			"cave": ["./packages/coding-agent/src/index.ts"],
			"cave/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"cave/*": ["./packages/coding-agent/src/*"],
			"@sinclair/typebox": ["./node_modules/@sinclair/typebox"],
			"@cave/mom": ["./packages/mom/src/index.ts"],
			"@cave/mom/*": ["./packages/mom/src/*"],
			"@cave/pods": ["./packages/pods/src/index.ts"],
			"@cave/pods/*": ["./packages/pods/src/*"],
			"@cave/tui": ["./packages/tui/src/index.ts"],
			"@cave/tui/*": ["./packages/tui/src/*"],
			"@cave/web-ui": ["./packages/web-ui/src/index.ts"],
			"@cave/web-ui/*": ["./packages/web-ui/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/coding-agent/examples/**/*"],
	"exclude": ["packages/web-ui/**/*", "**/dist/**"]
}
